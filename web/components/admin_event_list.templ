package components

import (
	"fmt"
	"github.com/naozine/project_crud_with_auth_tmpl/internal/database"
)

templ AdminEventList(events []database.Event) {
	<div class="max-w-5xl mx-auto space-y-6">
		@ListPageHeader("イベント管理", "イベントの管理ができます。") {
			@PrimaryLink("新規イベント", "/admin/events/new")
		}

		if len(events) == 0 {
			@EmptyState("イベントがまだありません。最初のイベントを作成しましょう。")
		} else {
			<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
				for _, e := range events {
					<a href={ templ.URL(fmt.Sprintf("/admin/events/%d", e.ID)) } class="group block rounded-lg border border-gray-200 bg-white p-6 hover:border-gray-300 hover:shadow-md transition-all duration-200">
						<div class="flex flex-col h-full justify-between space-y-4">
							<div>
								<h3 class="text-base font-semibold text-gray-900 group-hover:text-indigo-600 transition-colors">{ e.Title }</h3>
								<p class="mt-1 text-sm text-gray-500">{ e.Venue }</p>
								<p class="mt-1 text-xs text-gray-400">{ e.EventDate.Format("2006年1月2日 15:04") }</p>
							</div>
							<div class="flex items-center justify-between pt-4 border-t border-gray-50">
								if e.IsPublished {
									<span class="text-xs font-medium text-green-700 bg-green-50 px-2 py-1 rounded-full ring-1 ring-inset ring-green-600/20">公開中</span>
								} else {
									<span class="text-xs font-medium text-gray-500 bg-gray-100 px-2 py-1 rounded-full">下書き</span>
								}
								<span class="text-xs text-gray-400">定員: { fmt.Sprintf("%d", e.Capacity) }名</span>
							</div>
						</div>
					</a>
				}
			</div>
		}
	</div>
}
